# ============================================================
# NexusRecon Environment Configuration
# Copy to .env and populate with your API keys.
# NEVER commit .env to version control.
# ============================================================

# ── LLM Providers ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Primary LLM: "anthropic", "openai", "ollama"
NEXUS_LLM_PROVIDER=anthropic
NEXUS_LLM_MODEL=claude-opus-4-5
NEXUS_LLM_TEMPERATURE=0.1

# ── Infrastructure Intel ─────────────────────────────────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=
GREYNOISE_API_KEY=
BINARYEDGE_API_KEY=
FULLHUNT_API_KEY=
ABUSEIPDB_API_KEY=
URLSCAN_API_KEY=
SECURITYTRAILS_API_KEY=
ZOOMEYE_API_KEY=
NETLAS_API_KEY=
# Optional — 50k req/month free without a key; key unlocks VPN/proxy/TOR/hosting flags
IPINFO_API_KEY=
# Optional — free tier works without key; key raises rate limits
LEAKIX_API_KEY=

# ── Email / Identity ─────────────────────────────────────────
HUNTER_API_KEY=
EMAILREP_API_KEY=
HAVEIBEENPWNED_API_KEY=
DEHASHED_USERNAME=
DEHASHED_API_KEY=
INTELX_API_KEY=
LEAKCHECK_API_KEY=

# ── Vulnerability Intelligence ───────────────────────────────
VULNERS_API_KEY=

# ── Passive Source Rate-Limit Keys (optional — tools work without them) ──
OTX_API_KEY=
CERTSPOTTER_API_KEY=
CHAOS_API_KEY=

# ── Pretext & HUMINT ─────────────────────────────────────────
CRUNCHBASE_API_KEY=
# Optional — enables live Bing search for LinkedIn dorks and public collab tools
BING_SEARCH_API_KEY=

# ── Code / Repo ──────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITLAB_TOKEN=
BITBUCKET_TOKEN=

# ── Cloud Providers ──────────────────────────────────────────
# AWS credentials for account-level recon (read-only recommended)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── OPSEC / Proxy ────────────────────────────────────────────
# SOCKS5 proxy for outbound requests
NEXUS_PROXY_URL=socks5://127.0.0.1:9050
# Tor SOCKS5 (default Tor port)
NEXUS_TOR_PROXY=socks5://127.0.0.1:9050
# Custom DNS resolvers (comma-separated)
NEXUS_DNS_RESOLVERS=1.1.1.1,8.8.8.8,9.9.9.9
# Route credential validation calls through Tor to hide operator IP from cloud
# provider logs (requires Tor running on NEXUS_TOR_PROXY port). Default: false.
NEXUS_VALIDATE_VIA_TOR=false

# ── Storage ──────────────────────────────────────────────────
# Directory for campaign output (default: ./campaigns)
NEXUS_OUTPUT_DIR=./campaigns
# SQLite database path for state + cache
NEXUS_DB_PATH=./nexusrecon.db

# ── Vault Integration (optional) ─────────────────────────────
# 1Password service account token
OP_SERVICE_ACCOUNT_TOKEN=
# HashiCorp Vault
VAULT_ADDR=
VAULT_TOKEN=

# ── Debug / Dev ──────────────────────────────────────────────
NEXUS_LOG_LEVEL=INFO
NEXUS_LOG_FORMAT=json
NEXUS_DRY_RUN=false
